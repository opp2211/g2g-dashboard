example.com {
    root * /srv/g2g-dashboard/current
    encode zstd gzip

    handle /healthz {
        respond "ok" 200
    }

    handle /assets/* {
        header Cache-Control "public, max-age=31536000, immutable"
        file_server
    }

    handle {
        try_files {path} /index.html
        header Cache-Control "no-cache"
        file_server
    }
}
